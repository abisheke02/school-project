# ─────────────────────────────────────────────
# LD Support Platform — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# ── Server ──────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL (AWS RDS in production) ──────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ld_platform
DB_USER=ld_user
DB_PASSWORD=ld_password_dev

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────
# Generate a strong random secret for production:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_strong_random_secret

# ── Firebase Admin (backend) ─────────────────
# Get from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# ── Firebase Web SDK (teacher dashboard) ─────
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Claude / Anthropic API ───────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Google Cloud (TTS + STT) ─────────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── AWS S3 (audio files, PDF reports) ────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=ld-platform-assets

# ── Razorpay (payments — Phase 6) ────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ── Twilio (parent SMS digest — Phase 5) ─────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ── Allowed origins for CORS ─────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com
